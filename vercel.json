{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/rates",
      "destination": "/_/backend/rates"
    },
    {
      "source": "/health",
      "destination": "/_/backend/health"
    }
  ]
}
